{
  "deny": [
    "Read(.env)",
    "Edit(.env)",
    "Bash(cat .env)",
    "Bash(cat *.env)",
    "Bash(cat */.env)",
    "Bash(less .env)",
    "Bash(more .env)",
    "Bash(head .env)",
    "Bash(tail .env)",
    "Bash(grep .env)",
    "Bash(echo $NGC_API_KEY)",
    "Bash(env | grep NGC)",
    "Bash(printenv NGC)"
  ]
}
